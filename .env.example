# 复制为 .env 并填入你自己的值(.env 已被 .gitignore,不会提交)

# 智谱 BigModel API Key(出表格识别 glm-4v-flash + 导航 autoglm-phone 都用它)
# 申请:https://open.bigmodel.cn  →  控制台 API Keys
BIGMODEL_API_KEY=你的智谱key

# 反向通道(agent_client.py 用):你的 agent 服务端基址,需实现 /food-bridge/poll 和 /food-bridge/result
# 仅命令行(bridge.py)直接用时可不填
FRAMEWORK_URL=https://your-agent-server.example.com
# 与服务端共享的鉴权密钥(自己生成一个长随机串,两端填一样)
FOOD_BRIDGE_TOKEN=换成你自己的长随机串

# WiFi ADB 目标(可选):填了 agent_client 每次干活前会幂等重连,WiFi 掉了自动恢复
# 用 USB 连接则留空。手机 IP 查:adb shell ip -f inet addr show wlan0
FOOD_BRIDGE_ADB_TARGET=
